# Copy to staging/.env.staging (the setup script sources this file).
# Points Prisma at the local staging container from docker-compose.staging.yml.
# Host port 5434 — the native Postgres on 5433 is unrelated and untouched.
# LOCAL THROWAWAY CREDENTIALS — do not reuse anywhere real.

DATABASE_URL="postgresql://aloft:aloft@localhost:5434/aloftdb?schema=public"
DIRECT_URL="postgresql://aloft:aloft@localhost:5434/aloftdb?schema=public"

# Phase A: writes on, retrieval weighting OFF.
MEMORY_REPUTATION_ENABLED=true
# MEMORY_REPUTATION_WEIGHTING intentionally unset.
REPUTATION_SEASON=S1
