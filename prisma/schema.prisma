  ttl_ms              Int?
  payload_schema_id   String?   @db.Uuid
  version             String?   @default("1.0.0")
  description         String?
  author              String?
  status              String?   @default("draft")
  tags                String[]  @default([])
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)

  @@index([slug], map: "idx_bus_contract_catalog_slug")
  @@index([status], map: "idx_bus_contract_catalog_status")
  @@index([updated_at(sort: Desc)], map: "idx_bus_contract_catalog_updated")
