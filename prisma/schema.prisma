  @@index([source], map: "idx_prompt_templates_source")
  @@map("prompt_templates")
}

model workbench_sessions {
  id                       String                        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                  String?
  title                    String?
  messages                 Json?                         @default("[]")
  attached_tools           Json?                         @default("[]")
  attached_schemas         Json?                         @default("[]")
  attached_agents          Json?                         @default("[]")
  draft                    Json?
  artifact_type            String?                       @default("agent")
  artifact_draft           Json?
  pinned                   Boolean?                      @default(false)
  progress                 Json?
  saved_agent_id           String?                       @db.Uuid
  parent_session_id        String?                       @db.Uuid
  branch_point_message_idx Int?
  created_at               DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?                     @default(now()) @db.Timestamptz(6)
  message_count            Int?                          @default(0)
  last_message             String?
  construction_state       Json?
  modality                 String?
  readiness                String?
  surface                  String?
  context_mode             String?
  interaction_events       platform_interaction_events[]
  studio_results           studio_query_results[]

  @@index([user_id, updated_at(sort: Desc)], map: "idx_workbench_sessions_user")
  @@index([user_id, artifact_type], map: "idx_workbench_sessions_user_type")
  @@index([pinned], map: "idx_workbench_sessions_pinned")
  @@map("workbench_sessions")
}

model studio_query_results {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  session_id          String             @db.Uuid
  seq                 Int
  sql                 String
  columns             Json
  rows                Json
  row_count           Int
  truncated           Boolean            @default(false)
  profiles            Json?
  specs               Json?
  created_at          DateTime           @default(now()) @db.Timestamptz(6)
  chart_overrides     Json?
  active_result_index Int?
  insights            studio_insights?
  session             workbench_sessions @relation(fields: [session_id], references: [id], onDelete: Cascade)

  @@unique([session_id, seq])
  @@index([session_id], map: "idx_studio_qr_session")
  @@map("studio_query_results")
}

model studio_insights {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  result_id      String               @unique @db.Uuid
  session_id     String               @db.Uuid
  insights       Json
  prompt_version String               @default("insights_v1")
  model          String?
  input_tokens   Int?
  output_tokens  Int?
  cost_usd       Decimal?             @db.Decimal(10, 6)
  duration_ms    Int?
  created_at     DateTime             @default(now()) @db.Timestamptz(6)
  result         studio_query_results @relation(fields: [result_id], references: [id], onDelete: Cascade)

  @@index([session_id], map: "idx_studio_insights_session")
  @@map("studio_insights")
}

