// ============================================================
// USERS / RBAC / AUTH-SESSION DOMAIN  (ported from target design)
//
// Reconciliation notes:
//  - FK columns that reference User.id are `String` (text), because the existing
//    `User.id` is `cuid()` text — NOT retyped to uuid (kept additive).
//  - New tables use snake_case @@map / @map exactly per the target design.
//  - LlmCall & AuditLog keep the partition-ready composite PK (@@id([id, createdAt]))
//    but are created as PLAIN tables (no PARTITION BY) for now. See MIGRATION_RUNBOOK
//    Phase 5b to enable pg_partman range partitioning later.
// ============================================================

enum UserStatus {
  ACTIVE
  SUSPENDED
  INVITED
  DEACTIVATED
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique // "admin" | "member" | "viewer"
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique // e.g. "session:read", "user:delete"
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId     String   @map("user_id") // FK to User.id (cuid/text)
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")
  assignedBy String?  @map("assigned_by") // user id (text); no FK constraint

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

/// Authentication event / login record. In the stateless-AAD model this records
/// login events for audit; `refreshTokenHash` stays null (populated only if a
/// server-session/refresh-token model is adopted later — see runbook Phase 3).
model UserSession {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") // FK to User.id (cuid/text)
  refreshTokenHash String?   @unique @map("refresh_token_hash")
  userAgent        String?   @map("user_agent")
  ipAddress        String?   @map("ip_address") @db.Inet
  deviceId         String?   @map("device_id")
  expiresAt        DateTime? @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  lastActiveAt     DateTime  @default(now()) @map("last_active_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("user_sessions")
}

/// An application/agent/conversation session that groups work.
model Session {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String?       @map("user_id") // FK to User.id (cuid/text)
  title     String?
  type      String        @default("chat") // chat | agent | workflow | job
  status    SessionStatus @default(ACTIVE)
  metadata  Json?         @db.JsonB
  startedAt DateTime      @default(now()) @map("started_at")
  endedAt   DateTime?     @map("ended_at")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  user     User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  actions  Action[]
  llmCalls LlmCall[]
  audits   AuditLog[]

  @@index([userId])
  @@index([status])
  @@index([userId, startedAt])
  @@map("sessions")
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  FAILED
  ABORTED
}

/// A discrete step inside a session. Self-referencing via parentActionId.
/// NOT partitioned (referenced by FKs); rely on indexes + retention.
model Action {
  id             String       @id @default(uuid()) @db.Uuid
  sessionId      String       @map("session_id") @db.Uuid
  userId         String?      @map("user_id") // FK to User.id (cuid/text)
  parentActionId String?      @map("parent_action_id") @db.Uuid
  type           String // tool_call | http_request | db_query | user_input | system
  name           String
  status         ActionStatus @default(PENDING)
  sequence       Int          @default(0)
  input          Json?        @db.JsonB
  output         Json?        @db.JsonB
  error          String?
  startedAt      DateTime     @default(now()) @map("started_at")
  completedAt    DateTime?    @map("completed_at")
  durationMs     Int?         @map("duration_ms")
  createdAt      DateTime     @default(now()) @map("created_at")

  session  Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parent   Action?   @relation("ActionTree", fields: [parentActionId], references: [id], onDelete: Cascade)
  children Action[]  @relation("ActionTree")
  llmCalls LlmCall[]

  @@index([sessionId])
  @@index([sessionId, sequence])
  @@index([parentActionId])
  @@index([type])
  @@map("actions")
}

enum ActionStatus {
  PENDING
  RUNNING
  SUCCESS
  ERROR
  SKIPPED
}

/// A single LLM invocation with full trace + accounting.
/// PARTITION-READY: composite PK includes createdAt so this table can be
/// range-partitioned by month later. Created as a PLAIN table for now.
model LlmCall {
  id               String    @default(uuid()) @db.Uuid
  sessionId        String    @map("session_id") @db.Uuid
  actionId         String?   @map("action_id") @db.Uuid
  provider         String // openai | anthropic | google | azure | ...
  model            String
  requestId        String?   @map("request_id")
  status           LlmStatus @default(SUCCESS)
  promptTokens     Int?      @map("prompt_tokens")
  completionTokens Int?      @map("completion_tokens")
  totalTokens      Int?      @map("total_tokens")
  costUsd          Decimal?  @map("cost_usd") @db.Decimal(12, 6)
  latencyMs        Int?      @map("latency_ms")
  temperature      Float?
  finishReason     String?   @map("finish_reason")
  requestPayload   Json?     @map("request_payload") @db.JsonB // redact before write (Azure Key Vault envelope-encrypt here later)
  responsePayload  Json?     @map("response_payload") @db.JsonB
  error            String?
  createdAt        DateTime  @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  action  Action? @relation(fields: [actionId], references: [id], onDelete: SetNull)

  @@id([id, createdAt])
  @@index([sessionId])
  @@index([actionId])
  @@index([model])
  @@index([provider])
  @@index([createdAt])
  @@map("llm_calls")
}

enum LlmStatus {
  SUCCESS
  ERROR
  TIMEOUT
  RATE_LIMITED
}

/// Append-only audit trail. PARTITION-READY (composite PK); PLAIN table for now.
model AuditLog {
  id         String   @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") // null = system / automated; FK to User.id (cuid/text)
  action     String // "user.role.assigned", "session.deleted", ...
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  sessionId  String?  @map("session_id") @db.Uuid
  before     Json?    @db.JsonB
  after      Json?    @db.JsonB
  ipAddress  String?  @map("ip_address") @db.Inet
  userAgent  String?  @map("user_agent")
  metadata   Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at")

  actor   User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  session Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@id([id, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
