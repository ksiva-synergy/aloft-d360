/// Phase 3.5D — NL-intent embeddings for authored definitions & raw-SQL charts.
///
/// A PARALLEL table (not an extra row-kind on platform_context_embeddings)
/// because that table's subject_id is @db.Uuid with a UNIQUE(subject_kind,
/// subject_id) keyed to context objects/columns, whereas semantic-definition
/// and chart IDs are cuid2 strings — they cannot cleanly share the UUID column
/// or the unique key. Same Titan-v2 embedding path (embedQuery), 1024-dim.
///
/// Status is intentionally NOT denormalised here: matching JOINs live to the
/// source row (platform_sem_measures / platform_sem_dimensions / platform_charts)
/// so a promote/demote is reflected instantly with no status-sync writes.
model PlatformNlIntentEmbedding {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  org_id      String
  source_type String // 'measure' | 'dimension' | 'raw_chart'
  source_id   String // cuid2 of the definition / chart row (NOT a uuid)
  intent_text String
  embedding   Unsupported("vector")?
  model_id    String?
  created_by  String?
  created_at  DateTime               @default(now()) @db.Timestamptz(6)
  updated_at  DateTime               @default(now()) @db.Timestamptz(6)

  @@unique([source_type, source_id], map: "platform_nl_intent_embeddings_source_key")
  @@index([org_id], map: "idx_pnie_org")
  @@map("platform_nl_intent_embeddings")
}

