model agent_lab_messages {
  message_id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipeline_run_id          String                  @db.Uuid
  sender_agent_id          String
  receiver_agent_id        String
  message_type             String                  @default("request")
  schema_ref               String?
  payload                  Json                    @default("{}")
  correlation_id           String?                 @db.Uuid
  parent_message_id        String?                 @db.Uuid
  ttl_ms                   Int?
  priority                 Int?                    @default(0)
  metadata                 Json?                   @default("{}")
  created_at               DateTime?               @default(now()) @db.Timestamptz(6)
  schema_valid             Boolean?
  agent_lab_messages       agent_lab_messages?     @relation("agent_lab_messagesToagent_lab_messages", fields: [parent_message_id], references: [message_id], onDelete: NoAction, onUpdate: NoAction)
  other_agent_lab_messages agent_lab_messages[]    @relation("agent_lab_messagesToagent_lab_messages")
  agent_lab_pipeline_runs  agent_lab_pipeline_runs @relation(fields: [pipeline_run_id], references: [run_id], onDelete: Cascade, onUpdate: NoAction)

  @@index([correlation_id], map: "idx_messages_correlation")
  @@index([pipeline_run_id], map: "idx_messages_pipeline_run")
  @@index([receiver_agent_id], map: "idx_messages_receiver")
  @@index([sender_agent_id], map: "idx_messages_sender")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
