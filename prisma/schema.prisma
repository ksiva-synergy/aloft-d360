generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["postgresqlExtensions"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model User {
  id    String @id @default(cuid())
  email String @unique

  // --- Entra ID / AAD identity (added; new columns → snake_case per target design) ---
  aadObjectId String? @unique @map("aad_object_id") // token "oid" claim (stable per user)
  aadTenantId String? @map("aad_tenant_id") // token "tid" claim

  name          String?
  username      String?    @unique
  // NOTE: passwordHash widened to nullable (AAD users have none). Existing camelCase column kept — do NOT @map/rename.
  passwordHash  String?
  avatarUrl     String?    @map("avatar_url")
  // Existing column (from add_aad_sso_support.sql). Kept camelCase; AAD provisioning writes "aad".
  authProvider  String     @default("credentials")
  // Authoritative lifecycle (target). Legacy `isActive` kept in sync for the existing credentials/profile code.
  status        UserStatus @default(ACTIVE)
  emailVerified Boolean    @default(false) @map("email_verified")
  isActive      Boolean    @default(true)
  lastLoginAt   DateTime?  @map("last_login_at")
  lastSeenAt    DateTime?
  deletedAt     DateTime?  @map("deleted_at") // soft delete
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  // relations (existing — untouched)
  loginEvents                      LoginEvent[]
  profile                          UserProfile?
  platform_dashboard_collaborators platform_dashboard_collaborators[]

  // relations (added — RBAC + application-session / audit domain)
  roles        UserRole[]
  authSessions UserSession[]
  sessions     Session[]
  actions      Action[]
  auditLogs    AuditLog[]    @relation("AuditActor")

  @@index([status])
  @@index([deletedAt])
}

model UserProfile {
  id            String    @id @default(cuid())
  userId        String    @unique
  lastLoginAt   DateTime?
  lastLoginIp   String?
  loginCount    Int       @default(0)
  isActive      Boolean   @default(true)
  deactivatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model LoginEvent {
  id            String   @id @default(cuid())
  userId        String?
  email         String
  provider      String   @default("credentials")
  ipAddress     String?
  userAgent     String?
  success       Boolean
  failureReason String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model agent_catalog {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String
  slug              String?
  type              String?
  description       String?
  version           String?
  config            Json?     @default("{}")
  tools             Json?     @default("[]")
  input_schema      Json?     @default("{}")
  output_schema     Json?     @default("{}")
  bus_subscriptions Json?     @default("[]")
  bus_publications  Json?     @default("[]")
  tags              String[]  @default([])
  status            String?   @default("draft")
  author            String?
  parent_id         String?   @db.Uuid
  is_head           Boolean?  @default(false)
  draft_of_id       String?   @db.Uuid
  owner_id          String?   @db.Uuid
  reviewers         Json?     @default("[]")
  policy_ids        String[]  @default([])
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)

  @@index([slug], map: "idx_agent_catalog_slug")
  @@index([status], map: "idx_agent_catalog_status")
  @@index([type], map: "idx_agent_catalog_type")
  @@index([parent_id], map: "idx_agent_catalog_parent")
  @@index([updated_at(sort: Desc)], map: "idx_agent_catalog_updated")
  @@map("agent_catalog")
}

model bus_contract_catalog {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
