  @@index([agent_id, sheet_type], map: "idx_outcomes_agent_sheet")
  @@index([created_at(sort: Desc)], map: "idx_outcomes_created")
  @@index([job_id], map: "idx_outcomes_job")
  @@index([model_used], map: "idx_outcomes_model")
  @@index([outcome_type], map: "idx_outcomes_type")
}

